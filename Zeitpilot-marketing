<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>ZeitPilot – Zeiterfassung</title>

<style>

* {
    box-sizing: border-box;
}

body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    background: #0b0f19;
    color: white;
    line-height: 1.6;
}

.container {
    max-width: 1100px;
    margin: auto;
    padding: 60px 24px;
}

.logo {
    display: block;
    margin: 0 auto 24px auto;

    width: 220px;
    max-width: 80%;
    border-radius: 28px;

    box-shadow: 0 12px 40px rgba(0,0,0,0.45);
}

.hero {
    text-align: center;
    padding: 100px 0 80px;
}

.badge {
    display: inline-block;
    padding: 10px 18px;
    background: rgba(125, 211, 252, 0.1);
    border: 1px solid rgba(125, 211, 252, 0.25);
    color: #7dd3fc;
    border-radius: 999px;
    font-size: 14px;
    margin-bottom: 24px;
}

.hero h1 {
    font-size: 72px;
    line-height: 1;
    margin-bottom: 24px;
    font-weight: 800;
    letter-spacing: -2px;
}

.hero p {
    font-size: 22px;
    color: #b8c1d1;
    max-width: 760px;
    margin: auto;
}

.hero-buttons {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
}

.btn {
    padding: 16px 28px;
    border-radius: 16px;
    border: none;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: 0.25s ease;
}

.btn-primary {
    background: #7dd3fc;
    color: #0b0f19;
}

.btn-primary:hover {
    transform: translateY(-2px);
}

.btn-secondary {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
}

.btn-secondary:hover {
    background: rgba(255,255,255,0.08);
}

.section {
    margin-top: 90px;
}

.section-title {
    font-size: 42px;
    margin-bottom: 14px;
    text-align: center;
}

.section-subtitle {
    text-align: center;
    color: #b8c1d1;
    max-width: 720px;
    margin: auto auto 50px;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
}

.card {
    background: #151b2c;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 24px;
    padding: 30px;
    transition: 0.25s ease;
}

.card:hover {
    transform: translateY(-5px);
    border-color: rgba(255,255,255,0.18);
}

.card h2 {
    margin-top: 0;
    font-size: 24px;
}

.card p {
    color: #b8c1d1;
    margin-bottom: 0;
}

.premium {
    background: linear-gradient(135deg, #1f2940, #111827);
}

.showcase {
    margin-top: 80px;

    background: linear-gradient(
        135deg,
        rgba(125,211,252,0.08),
        rgba(255,255,255,0.02)
    );

    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 32px;

    padding: 60px 40px;

    text-align: center;
}

.showcase h2 {
    font-size: 42px;
    margin-bottom: 18px;
}

.showcase p {
    color: #b8c1d1;
    max-width: 760px;
    margin: auto;
}

.footer {
    text-align: center;
    margin-top: 120px;
    color: #7f8aa3;
    font-size: 15px;
}

.highlight {
    color: #7dd3fc;
}

@media (max-width: 768px) {

    .hero h1 {
        font-size: 48px;
    }

    .hero p {
        font-size: 18px;
    }

    .section-title {
        font-size: 32px;
    }

    .logo {
        width: 170px;
    }

}

</style>
</head>

<body>

<div class="container">

